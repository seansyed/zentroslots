# ─── ZentroMeet Mobile — environment ─────────────────────────────
# Copy this to .env for local Expo dev. EAS builds DON'T read .env
# files by default — they read `env` blocks inside eas.json (already
# set to https://app.zentromeet.com for every profile).
#
# Reading order in src/lib/env.ts:
#   1. process.env.EXPO_PUBLIC_*      (statically inlined at build)
#   2. app.json `extra` block         (Constants.expoConfig.extra)
#   3. hardcoded default              (last resort)

# Production API base — every endpoint in src/api/* is suffixed onto this.
EXPO_PUBLIC_API_BASE_URL=https://app.zentromeet.com

# Optional override for a staging server.
# EXPO_PUBLIC_API_BASE_URL=https://staging.zentromeet.com
