{
  "expo": {
    "name": "ZentroMeet",
    "slug": "zentromeet-mobile",
    "version": "1.0",
    "description": "Mobile command center for ZentroMeet — manage bookings, confirm appointments, message customers, and run your schedule from anywhere.",
    "primaryColor": "#2563EB",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "zentromeet",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zentromeet.app",
      "buildNumber": "20",
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:app.zentromeet.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "ZentroMeet does not access your camera. This permission string is required by the system but the feature is not used.",
        "NSMicrophoneUsageDescription": "ZentroMeet does not access your microphone. This permission string is required by the system but the feature is not used.",
        "NSPhotoLibraryUsageDescription": "ZentroMeet does not access your photo library.",
        "NSContactsUsageDescription": "ZentroMeet does not access your contacts.",
        "NSLocationWhenInUseUsageDescription": "ZentroMeet does not use your location."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563EB"
      },
      "package": "com.zentromeet.app",
      "versionCode": 21,
      "permissions": [
        "INTERNET",
        "POST_NOTIFICATIONS",
        "VIBRATE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "zentromeet",
              "host": "oauth"
            }
          ]
        },
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "app.zentromeet.com",
              "pathPrefix": "/m"
            }
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#f5faff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 35,
            "ndkVersion": "27.1.12297006"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://app.zentromeet.com",
      "privacyPolicyUrl": "https://app.zentromeet.com/privacy",
      "termsUrl": "https://app.zentromeet.com/terms",
      "supportEmail": "support@zentromeet.com",
      "router": {
        "origin": false
      },
      "_easComment": "Run `npx eas init` once — the CLI writes extra.eas.projectId and the top-level `owner` field here automatically. Don't set them by hand.",
      "eas": {
        "projectId": "015c17c4-5ba8-4a4f-9516-1022329068c5"
      }
    },
    "owner": "seansyed",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/015c17c4-5ba8-4a4f-9516-1022329068c5"
    }
  }
}
