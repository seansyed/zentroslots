{
  "name": "zentromeet-mobile",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "prebuild": "expo prebuild",
    "assets:generate": "node scripts/generate-placeholder-assets.js",
    "eas:login": "npx eas-cli login",
    "eas:whoami": "npx eas-cli whoami",
    "eas:init": "npx eas-cli init",
    "build:android:preview": "npx eas-cli build --profile preview --platform android",
    "build:ios:preview": "npx eas-cli build --profile preview --platform ios",
    "build:android:production": "npx eas-cli build --profile production --platform android",
    "build:ios:production": "npx eas-cli build --profile production --platform ios",
    "build:dev:android": "npx eas-cli build --profile development --platform android",
    "build:list": "npx eas-cli build:list",
    "submit:ios": "npx eas-cli submit -p ios --profile production",
    "submit:android": "npx eas-cli submit -p android --profile production",
    "web:deploy": "bash scripts/deploy-web.sh"
  },
  "dependencies": {
    "@expo-google-fonts/public-sans": "^0.2.3",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.59.16",
    "axios": "^1.7.7",
    "expo": "^56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-build-properties": "~56.0.19",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-linking": "~56.0.14",
    "expo-notifications": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-web-browser": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  }
}
