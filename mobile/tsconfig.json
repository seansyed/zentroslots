{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Node built-in type defs for the tsx-run test files (node:test,
    // node:assert/strict, node:fs, node:path). App + RN/React types still
    // resolve via module imports, so this does not affect runtime code.
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./app/*"]
    },
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules", ".expo", "dist", "web-build"]
}
