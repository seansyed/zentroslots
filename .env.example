# ────────────────────────────────────────────────────────────────────
# ZentroMeet — environment variables for scheduling-saas
#
# Local dev: copy this file to `.env` and fill in values.
# Production: edit /var/www/scheduling-saas/.env on the EC2 host
# directly (see DEPLOYMENT.md). DO NOT commit `.env`.
# ────────────────────────────────────────────────────────────────────

# ─── Core ──────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/scheduling

# Generate with: openssl rand -base64 32
JWT_SECRET=replace-me-with-32-bytes-of-randomness

# Used to build absolute URLs in OAuth flows + emails.
APP_BASE_URL=http://localhost:3001

# ─── OAuth: Google Sign-In + Google Calendar ──────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/google/callback

# ─── OAuth: Microsoft Sign-In + Outlook Calendar ──────────────────
# https://entra.microsoft.com → App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Email (one provider must be configured for prod) ─────────────
# Provider precedence in lib/email.ts: Resend → Postmark → SMTP → stub.
# In prod we run SMTP via AWS SES.
EMAIL_FROM=ZentroMeet <no-reply@zentromeet.com>
BRAND_NAME=ZentroMeet

# Option A: Resend (preferred — simpler than SES SMTP)
RESEND_API_KEY=

# Option B: Postmark
POSTMARK_TOKEN=

# Option C: SMTP (e.g. AWS SES)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SES_REGION=us-east-1

# ─── Platform-level inboxes ────────────────────────────────────────
# Public form notifications + admin operational alerts cascade through
# these. See lib/notify-support.ts + lib/admin-notify.ts.
SUPPORT_EMAIL=
DEMO_EMAIL=
ADMIN_EMAIL=
OPERATIONS_EMAIL=
SUPER_ADMIN_EMAILS=

# Cooldown between identical admin alerts (ms; default 15 min)
ADMIN_ALERT_COOLDOWN_MS=900000

# ─── Stripe (subscriptions + booking payments) ────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs per plan + interval. These names MUST match the keys read in
# lib/plans.ts (suffix _MONTH / _YEAR — NOT _MONTHLY / _YEARLY). If the
# names don't match, priceIdFor() returns null and every paid checkout CTA
# renders disabled ("Stripe price not configured"). See lib/stripe.ts.
STRIPE_PRICE_SOLO_MONTH=
STRIPE_PRICE_SOLO_YEAR=
STRIPE_PRICE_PRO_MONTH=
STRIPE_PRICE_PRO_YEAR=
STRIPE_PRICE_TEAM_MONTH=
STRIPE_PRICE_TEAM_YEAR=
STRIPE_PRICE_ENTERPRISE_MONTH=
STRIPE_PRICE_ENTERPRISE_YEAR=
# Legacy monthly-only fallbacks (pre-Phase-16 subscriptions keep billing
# at these Price IDs until migrated). Optional.
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=

# Business Phone add-on ($29/mo, 1,000 US/Canada minutes included; inbound call
# forwarding + click-to-call bridge; softphone coming soon; no emergency/911,
# no international). SERVER-SIDE ONLY — never exposed to client code.
# UNSET = feature DARK: no purchase path resolves and the Stripe webhook grants
# NO entitlement. Set this to the recurring monthly Price ID created in the
# Stripe Dashboard to turn the add-on on.
STRIPE_PRICE_BUSINESS_PHONE_MONTH=

# Business Phone softphone (Phase 2, WebRTC) availability flag. UNSET/false =
# the mobile + web softphone surfaces stay hidden ("coming soon"). Only set to
# "true" once the real softphone is built + signed off. Read by
# GET /api/tenant/phone/status (softphoneAvailable).
BUSINESS_PHONE_SOFTPHONE_AVAILABLE=false

# Soft-hold window for booking-payment flow (minutes). Code default is 15
# (lib/billing/paymentLifecycle.ts); leave unset in prod to use that.
PAYMENT_HOLD_MINUTES=15

# ─── Encryption for tenant-stored secrets ─────────────────────────
# Generate with: openssl rand -hex 32
# MUST be exactly 64 hex characters (32 bytes) — lib/crypto.ts parses it
# as hex and throws on any other length/encoding (a base64 value will
# fail and break calendar-token encryption). Used for encrypting calendar
# refresh tokens + external feed URLs.
COMMS_ENCRYPTION_KEY=

# ─── Analytics ─────────────────────────────────────────────────────
# GA4 Measurement ID. Must use NEXT_PUBLIC_* prefix to inline into
# client bundle. Unset = no script tag + zero network calls (safe dev).
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ─── Cloudflare (optional — custom domains feature) ───────────────
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_HOSTNAME_API_KEY=

# ─── Cookie / dev overrides ───────────────────────────────────────
# COOKIE_INSECURE=1   # never enable in production — set Secure=false
NODE_ENV=development
