# Dependencies
node_modules

# Build output
.next
*.tsbuildinfo
next-env.d.ts

# Secrets & local env
.env
.env.local
.env.production
.env.*.local

# Logs & dev artifacts
*.log
.devserver.log

# OS noise
.DS_Store
Thumbs.db

# Editor noise
.vscode/*.log
.idea

# User-uploaded assets (avatars, future uploads). Lives on EC2 disk;
# survives `next build` because public/ is preserved across builds.
# The .gitkeep directory placeholder is committed so the path
# exists on a fresh clone for the avatar upload route to write into.
public/uploads/*
!public/uploads/.gitkeep
!public/uploads/avatars/
public/uploads/avatars/*
!public/uploads/avatars/.gitkeep
!public/uploads/locations/
public/uploads/locations/*
!public/uploads/locations/.gitkeep
